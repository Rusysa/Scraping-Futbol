# ============================================================
#  Scraper de Fútbol — Variables de Entorno
#  Copia este archivo como .env y completa los valores reales.
#  NUNCA subas el archivo .env al repositorio.
# ============================================================

# ----------------------------------------------------------
# TELEGRAM (obligatorio)
# ----------------------------------------------------------

# Token del bot de Telegram.
# Cómo obtenerlo:
#   1. Abre Telegram y busca @BotFather
#   2. Ejecuta /newbot y sigue las instrucciones
#   3. Copia el token que te entrega (ej: 123456789:ABCdef...)
TELEGRAM_BOT_TOKEN=TU_TOKEN_AQUI

# ID del chat donde se enviarán los mensajes.
# Puede ser un chat personal, un grupo o un canal.
# Cómo obtenerlo:
#   1. Envíale cualquier mensaje a tu bot desde Telegram
#   2. Abre en el navegador:
#      https://api.telegram.org/bot<TU_TOKEN>/getUpdates
#   3. Busca el campo "id" dentro de "chat"
#      Para grupos el ID empieza con - (negativo), ej: -1001234567890
TELEGRAM_CHAT_ID=TU_CHAT_ID_AQUI

# ----------------------------------------------------------
# SCRAPING (opcional — se usan los valores por defecto si no se definen)
# ----------------------------------------------------------

# Expresión cron que define cuándo se envía el resumen (modo servidor local).
# Por defecto: todos los días a las 8:00 AM.
# Ejemplos:
#   "0 8 * * *"     → Cada día a las 8:00
#   "0 8 * * 1,4"   → Lunes y jueves a las 8:00
#   "0 20 * * 5"    → Viernes a las 20:00
SCRAPE_SCHEDULE=0 8 * * *

# Ligas a incluir en el resumen (separadas por coma, en minúsculas).
# Si se deja vacío, se incluyen todas las ligas del sitio.
# Por defecto: liga mx, liga bbva mx, selección mexicana
TARGET_LEAGUES=liga mx,liga bbva mx,selección mexicana

# Número de días hacia adelante a incluir en el resumen.
# Por defecto: 7
DAYS_TO_SCRAPE=7
